meta {
  name: Create Booking Past Date
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/bookings
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "roomId": {{roomId}},
    "startTime": "2020-01-01T10:00:00",
    "endTime": "2020-01-01T11:00:00",
    "purpose": "Passé"
  }
}

tests {
  test("status 400 validation Future", function() {
    expect(res.getStatus()).to.equal(400);
  });
}