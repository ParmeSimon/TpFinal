meta {
  name: Refresh With Access Token
  type: http
  seq: 7
}

post {
  url: {{baseUrl}}/api/auth/refresh
  body: json
  auth: none
}

body:json {
  {
    "refreshToken": "{{accessToken}}"
  }
}

tests {
  test("status 401 reject access token", function() {
    expect(res.getStatus()).to.equal(401);
  });
}