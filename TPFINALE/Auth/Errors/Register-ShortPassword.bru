meta {
  name: Register Short Password
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/api/auth/register
  body: json
  auth: none
}

body:json {
  {
    "firstName": "X",
    "lastName": "Y",
    "email": "shortpwd@ekod.fr",
    "password": "123"
  }
}

tests {
  test("status 400", function() {
    expect(res.getStatus()).to.equal(400);
  });
  test("password error message", function() {
    expect(JSON.stringify(res.getBody())).to.include("password");
  });
}