meta {
  name: Register Duplicate Email
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/auth/register
  body: json
  auth: none
}

body:json {
  {
    "firstName": "Lucien",
    "lastName": "Dup",
    "email": "{{studentEmail}}",
    "password": "Password123!"
  }
}

tests {
  test("status 400", function() {
    expect(res.getStatus()).to.equal(400);
  });
}