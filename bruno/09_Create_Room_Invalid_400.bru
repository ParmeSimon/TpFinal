meta {
  name: 09 - Create Room (corps invalide) → 400
  type: http
  seq: 9
}

post {
  url: {{baseUrl}}/api/rooms
  body: json
  auth: none
}

headers {
  Content-Type: application/json
  Authorization: Bearer {{adminToken}}
}

body:json {
  {
    "name": "",
    "available": true,
    "equipmentIds": []
  }
}

tests {
  test("status 400 Bad Request (nom vide, capacité absente)", function() {
    expect(res.getStatus()).to.equal(400);
  });
}