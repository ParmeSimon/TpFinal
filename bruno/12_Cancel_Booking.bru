meta {
  name: 12 - Cancel Booking → 200
  type: http
  seq: 12
}

put {
  url: {{baseUrl}}/api/bookings/{{bookingId}}/cancel
  body: none
  auth: none
}

headers {
  Authorization: Bearer {{userToken}}
}

tests {
  test("status 200 OK", function() {
    expect(res.getStatus()).to.equal(200);
  });
  test("statut passe à CANCELLED", function() {
    expect(res.getBody().status).to.equal("CANCELLED");
  });
}